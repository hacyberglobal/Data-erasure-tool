{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "public": true,
  "functions": {
    "api/**: {
      "memory": 128,
      "maxDuration": 10
    }
  }
}
